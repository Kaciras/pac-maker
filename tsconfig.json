{

	"include": ["src/**/*.ts"],
	"compilerOptions": {
		"moduleResolution": "NodeNext",
		"module": "NodeNext",
		"target": "ESNext",
		"resolveJsonModule": true,
		"skipLibCheck": true,
		"rootDir": "./src",
		"outDir": "lib",
		"sourceMap": true,
		"declaration": true,
		"useUnknownInCatchVariables": false
	}
}
